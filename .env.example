# --- App ---
APP_NAME=Trip Planner
APP_ENV=development
DEBUG=true

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://trip:trip@localhost:5432/trip_planner
SQL_ECHO=false

# --- API keys (see docs/setup-google-maps.md and docs/setup-anthropic.md) ---
# Leave blank for now — these are needed starting in Phase 2 (extract/enrich).
# ANTHROPIC_API_KEY is still used by the hotel/transport/budget specialist experts.
ANTHROPIC_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- Chat agent (Qwen over an OpenAI-compatible endpoint) ---
# Default: local Ollama — free & offline. Pull the model once:  ollama pull qwen3.5:9b
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_MODEL=qwen3.5:9b
QWEN_API_KEY=
# Hosted alternatives (set all three together):
#   DashScope:  QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  QWEN_MODEL=qwen-plus            QWEN_API_KEY=<key>
#   OpenRouter: QWEN_BASE_URL=https://openrouter.ai/api/v1                            QWEN_MODEL=qwen/qwen3-235b-a22b QWEN_API_KEY=<key>
# Web search uses keyless DuckDuckGo (the 'ddgs' package) — no key needed.

# --- CORS (comma-separated origins; * allows all, fine for local dev) ---
# When deploying, pin this to your real origin (e.g. https://trip.example.com) so the
# auth cookie can be sent cross-origin; '*' forces credentials off.
CORS_ORIGINS=*

# --- Auth (optional shared password) ---
# Leave blank for open local dev. Set a password in production to require sign-in at /login
# before viewing the plan, chatting, or editing tasks.
APP_SECRET=
