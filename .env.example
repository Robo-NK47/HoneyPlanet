# --- App ---
APP_NAME=Trip Planner
APP_ENV=development
DEBUG=true

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://trip:trip@localhost:5432/trip_planner
SQL_ECHO=false

# --- API keys (see docs/setup-google-maps.md and docs/setup-anthropic.md) ---
# Leave blank for now — these are needed starting in Phase 2 (extract/enrich).
ANTHROPIC_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- CORS (comma-separated origins; * allows all, fine for local dev) ---
CORS_ORIGINS=*
